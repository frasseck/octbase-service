# {{ ansible_managed }}
# Octbase client instance: {{ fqdn }} ({{ display_name | default(name) }})
#
# Created once by create-instance.yml and never overwritten as a whole —
# the per-client secrets below exist ONLY here. Two groups of keys are
# re-synced by ansible on every playbook run and must not be edited here:
#   - the "ledger-managed" block at the bottom (from ledger/clients/<name>.yml)
#   - platform-managed keys (from group_vars): OCTBASE_TRUSTED_PROXIES,
#     OCTBASE_SMTP_*, OCTBASE_*_RETENTION_DAYS.

COMPOSE_PROJECT_NAME=octbase

# Host ports, loopback-only: the edge reverse proxy is the sole public entry.
POSTGRES_PORT=127.0.0.1:{{ ports.postgres }}
API_PORT=127.0.0.1:{{ ports.api }}
FRONTEND_PORT=127.0.0.1:{{ ports.frontend }}

PGDATA_DIR=./pgdata

POSTGRES_DB=octbase
POSTGRES_USER=octbase
POSTGRES_PASSWORD={{ gen_pg_password }}

OCTBASE_DB_MAX_OPEN_CONNS=25
OCTBASE_DB_MAX_IDLE_CONNS=5

# ── Auth / crypto (unique per client, generated at first deploy) ──
OCTBASE_JWT_SECRET={{ gen_jwt_secret }}
OCTBASE_JWT_ACCESS_TTL=15m
OCTBASE_JWT_REFRESH_TTL=1h
OCTBASE_SCM_ENC_KEY={{ gen_scm_key }}
OCTBASE_MFA_ENC_KEY={{ gen_mfa_key }}

# ── Public origin ──
OCTBASE_CORS_ORIGIN=https://{{ fqdn }}
OCTBASE_APP_URL=https://{{ fqdn }}
OCTBASE_SECURE_COOKIES=true
OCTBASE_TRUSTED_PROXIES={{ octbase_trusted_proxies }}

# ── Mail ──
OCTBASE_SMTP_HOST={{ smtp_host }}
OCTBASE_SMTP_PORT={{ smtp_port }}
OCTBASE_SMTP_FROM={{ smtp_from }}
OCTBASE_SMTP_USER={{ smtp_user }}
OCTBASE_SMTP_PASS={{ smtp_pass }}

# ── GDPR retention ──
OCTBASE_AUDIT_RETENTION_DAYS={{ audit_retention_days }}
OCTBASE_ACTIVITY_RETENTION_DAYS={{ activity_retention_days }}

# ── OAuth / webhooks (fill in per client if booked) ──
OCTBASE_OAUTH_REDIRECT_BASE=
OCTBASE_OAUTH_GITHUB_CLIENT_ID=
OCTBASE_OAUTH_GITHUB_CLIENT_SECRET=
OCTBASE_OAUTH_GITLAB_CLIENT_ID=
OCTBASE_OAUTH_GITLAB_CLIENT_SECRET=
OCTBASE_OAUTH_BITBUCKET_CLIENT_ID=
OCTBASE_OAUTH_BITBUCKET_CLIENT_SECRET=
OCTBASE_WEBHOOK_SECRET_BITBUCKET=
OCTBASE_WEBHOOK_SECRET_GITHUB=

# ── App ──
OCTBASE_DEMO_MODE=false
PORT=8000
OCTBASE_ATTACHMENTS_DIR=/data/attachments
OCTBASE_MAX_UPLOAD_MB=25
OCTBASE_FEATURE_TASKVIEW=true
OCTBASE_LOG_LEVEL=info

# ── Ledger-managed (re-synced by ansible on every run; do not edit) ──
OCTBASE_EDITION={{ edition | upper }}
OCTBASE_OPTION_JIRA_IMPORT={{ 'true' if (jira_import | default(false)) else 'false' }}
OCTBASE_MAX_USERS={{ max_users }}
OCTBASE_APP_VERSION={{ app_version | default(octbase_version) }}

# {{ ansible_managed }}
# Octbase client instance: {{ fqdn }} ({{ client_ledger.display_name | default(client) }})
#
# Created once by create-instance.yml and never overwritten as a whole —
# the per-client secrets below exist ONLY here. Three groups of keys are
# re-synced by ansible on every playbook run and must not be edited here:
#   - the "ledger-managed" block at the bottom (from ledger/clients/<name>.yml)
#   - platform-managed keys (from group_vars): OCTBASE_TRUSTED_PROXIES,
#     OCTBASE_SMTP_*, OCTBASE_*_RETENTION_DAYS.
#   - the port block below: FRONTEND_BIND_ADDR, FRONTEND_PORT, API_PORT,
#     POSTGRES_PORT (ledger ports + the loopback bind that C9 requires).

COMPOSE_PROJECT_NAME=octbase

# Host ports, loopback-only: the edge reverse proxy is the sole public entry.
# Since app v1.0.7 the compose file prefixes the postgres/API mappings with
# ${BIND_ADDR:-127.0.0.1} itself — these two must be port-only, no IP.
# Since app release_v18 the frontend mapping is
# ${FRONTEND_BIND_ADDR:-0.0.0.0}:${FRONTEND_PORT:-8080}:8080, so FRONTEND_PORT
# is port-only as well and the interface comes from FRONTEND_BIND_ADDR. Its
# default is 0.0.0.0 — right for a standalone stack, which is its own public
# entry, wrong for a client stack behind the edge: 127.0.0.1 is what keeps
# C9 true. All four keys are re-synced on every create-instance run, so a
# client whose .env predates either mapping change is repaired in place
# rather than by hand (D20/D22).
POSTGRES_PORT={{ client_ledger.ports.postgres }}
API_PORT={{ client_ledger.ports.api }}
FRONTEND_BIND_ADDR=127.0.0.1
FRONTEND_PORT={{ client_ledger.ports.frontend }}

PGDATA_DIR=./pgdata

POSTGRES_DB=octbase
POSTGRES_USER=octbase
POSTGRES_PASSWORD={{ gen_pg_password }}

OCTBASE_DB_MAX_OPEN_CONNS=25
OCTBASE_DB_MAX_IDLE_CONNS=5

# ── Auth / crypto (unique per client, generated at first deploy) ──
OCTBASE_JWT_SECRET={{ gen_jwt_secret }}
OCTBASE_JWT_ACCESS_TTL=15m
OCTBASE_JWT_REFRESH_TTL=1h
OCTBASE_SCM_ENC_KEY={{ gen_scm_key }}
OCTBASE_MFA_ENC_KEY={{ gen_mfa_key }}

# ── Initial administrator (consumed once, at the first API start) ──
# The app creates this SUPER_ADMIN while the users table is still empty and
# ignores the keys forever after, so they stay here harmlessly. Without them a
# client instance would have no way in at all: the app has no signup and no
# first-run flow, and its user API refuses to assign SUPER_ADMIN.
# The password is a BCRYPT HASH — the plaintext is printed once by
# create-instance.yml and never stored, so this file holds no reusable human
# credential (only machine secrets, as everywhere else in it).
OCTBASE_BOOTSTRAP_ADMIN_EMAIL={{ admin_email }}
OCTBASE_BOOTSTRAP_ADMIN_PASSWORD_HASH={{ gen_admin_password_hash | default('') }}

# ── Public origin ──
OCTBASE_CORS_ORIGIN=https://{{ fqdn }}
OCTBASE_APP_URL=https://{{ fqdn }}
OCTBASE_SECURE_COOKIES=true
OCTBASE_TRUSTED_PROXIES={{ octbase_trusted_proxies }}

# ── Mail ──
OCTBASE_SMTP_HOST={{ smtp_host }}
OCTBASE_SMTP_PORT={{ smtp_port }}
OCTBASE_SMTP_FROM={{ smtp_from }}
OCTBASE_SMTP_USER={{ smtp_user }}
OCTBASE_SMTP_PASS={{ smtp_pass }}

# ── GDPR retention ──
OCTBASE_AUDIT_RETENTION_DAYS={{ audit_retention_days }}
OCTBASE_ACTIVITY_RETENTION_DAYS={{ activity_retention_days }}

# ── OAuth / webhooks (fill in per client if booked) ──
OCTBASE_OAUTH_REDIRECT_BASE=
OCTBASE_OAUTH_GITHUB_CLIENT_ID=
OCTBASE_OAUTH_GITHUB_CLIENT_SECRET=
OCTBASE_OAUTH_GITLAB_CLIENT_ID=
OCTBASE_OAUTH_GITLAB_CLIENT_SECRET=
OCTBASE_OAUTH_BITBUCKET_CLIENT_ID=
OCTBASE_OAUTH_BITBUCKET_CLIENT_SECRET=
OCTBASE_WEBHOOK_SECRET_BITBUCKET=
OCTBASE_WEBHOOK_SECRET_GITHUB=

# ── App ──
OCTBASE_DEMO_MODE=false
PORT=8000
OCTBASE_ATTACHMENTS_DIR=/data/attachments
# Upload limits (product defaults: 10 MB per file, 512 MB = 0.5 GB total
# storage per user; 0 disables a limit). Edit here for one-off client deals;
# a redeploy keeps the values since this block is created once.
OCTBASE_MAX_UPLOAD_MB=10
OCTBASE_MAX_USER_STORAGE_MB=512
OCTBASE_FEATURE_TASKVIEW=true
OCTBASE_LOG_LEVEL=info

# ── Ledger-managed (re-synced by ansible on every run; do not edit) ──
OCTBASE_EDITION={{ client_ledger.edition | upper }}
OCTBASE_OPTION_JIRA_IMPORT={{ 'true' if (client_ledger.jira_import | default(false)) else 'false' }}
OCTBASE_MAX_USERS={{ client_ledger.max_users }}
OCTBASE_APP_VERSION={{ client_ledger.app_version | default(octbase_version) }}
